# --- Splits (Terminator Style) ---
keybind = ctrl+shift+o=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+e=new_split:right

# --- Navigation (Alt + Arrow Keys) ---
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

# --- Visuals & Typography ---
adjust-cell-height = 10%
font-family = "FiraCode Nerd Font Mono"
font-size = 10
theme = Gruvbox Dark
window-colorspace = "display-p3"
font-feature = -liga
font-feature = -calt

# --- Opacity & Blur ---
background-blur = true
background-opacity = 0.98
background-blur-radius = 20

# --- Cursor --- 
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# --- Interaction & Compatibility ---
copy-on-select = clipboard
keybind = cmd+v=paste_from_clipboard
term = xterm-256color
