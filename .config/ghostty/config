# --- Splits (Terminator Style) ---
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+e=new_split:right

# --- Navigation (Alt + Arrow Keys) ---
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

# --- Visuals & Typography ---
adjust-cell-height = 20%
font-family = "JetBrainsMono Nerd Font"
font-size = 12
theme = TokyoNight
window-colorspace = "display-p3"

# --- macOS Polish ---
macos-non-native-fullscreen = true
macos-titlebar-style = tabs
macos-option-as-alt = true
window-save-state = always

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# --- Interaction & Compatibility ---
copy-on-select = clipboard
keybind = cmd+v=paste_from_clipboard
term = xterm-256color
